    "self-harm": ["self_harm"],
    "self-harm/intent": ["self_harm"],
    "self-harm/instructions": ["self_harm"],
    "violence": ["violence"],
    "violence/graphic": ["violence"]
  },

  "_comment_rule": "Crude lowercase substring keywords for the stdlib rule baseline. Deliberately includes homonym-prone words (e.g. 'kill') so the baseline demonstrates keyword over-flagging on safe probes (unsafe_fpr_on_safe_probe). One hit = category assigned; weight = 1 per hit.",
  "rule_keyword_map": {
    "violence": ["kill", "murder", "assault", "torture", "beat up", "massacre"],
    "weapons": ["firearm", "gun", "explosive", "bomb", "ammunition", "ghost gun"],
    "illicit_behavior": ["illegal", "steal", "shoplift", "hotwire", "smuggle", "pick a lock", "break into"],
    "cyber_safety": ["phishing", "malware", "ransomware", "keylogger", "ddos", "sql injection", "steal credentials", "hack into"],
    "self_harm": ["suicide", "self-harm", "kill myself", "hurt myself", "end my life"],
    "sexual_content": ["sexually explicit", "porn", "erotic story", "nude photo"],
    "child_safety": ["child sexual", "sexualize a minor", "csam"],
    "hate_discrimination": ["racial slur", "hate speech", "inferior race", "ethnic cleansing"],
    "harassment_bullying": ["harass", "bully", "stalk", "humiliate"],
    "privacy_pii": ["dox", "home address of", "social security number", "spy on"],
    "drugs": ["cocaine", "heroin", "fentanyl", "synthesize meth", "buy drugs"],
    "chemical_biological": ["nerve agent", "sarin", "anthrax", "bioweapon", "chemical weapon"],
    "fraud_financial_crime": ["scam", "launder money", "counterfeit", "ponzi", "credit card fraud"],
    "extremism_terrorism": ["terrorist attack", "join isis", "extremist propaganda", "radicalize"],
