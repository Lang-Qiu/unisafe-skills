{
  "taxonomy_version": "unified-taxonomy-v1-2026-06",
  "_comment_policy": "Map when possible; unmappable -> 'other'; unsafe with no category -> 'general_harm'. Raw guard labels are ALWAYS preserved in raw_output, so every mapping here stays auditable and remappable. Values are lists (one source label may map to multiple canonical categories, taxonomy.md principle 1).",

  "llama_guard_s_to_canonical": {
    "S1": ["violence"],
    "S2": ["illicit_behavior"],
    "S3": ["sexual_content"],
    "S4": ["child_safety"],
    "S5": ["general_harm"],
    "S6": ["medical_safety", "legal_safety"],
    "S7": ["privacy_pii"],
    "S8": ["copyright"],
    "S9": ["chemical_biological"],
    "S10": ["hate_discrimination"],
    "S11": ["self_harm"],
    "S12": ["sexual_content"],
    "S13": ["political_persuasion"],
    "S14": ["cyber_safety"]
  },

  "_comment_openai": "Kept for the llm_judge extension (E1): normalizes OpenAI-moderation-style category names returned by LLM judges into the canonical taxonomy.",
  "openai_to_canonical": {
    "sexual": ["sexual_content"],
    "sexual/minors": ["child_safety"],
    "harassment": ["harassment_bullying"],
    "harassment/threatening": ["harassment_bullying"],
    "hate": ["hate_discrimination"],
    "hate/threatening": ["hate_discrimination"],
